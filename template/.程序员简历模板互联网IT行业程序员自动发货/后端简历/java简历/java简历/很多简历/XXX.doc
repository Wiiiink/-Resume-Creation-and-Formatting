.0000pt ;" ><tr><td width=3D83  valign=3Dtop  style=3D"width:62.3000pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(102,102,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >主题：</span><span style=3D"font-family:微软雅黑;color:rgb(102,102,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td><td width=3D578  valign=3Dtop  style=3D"width:434.1500pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><b><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-weight:bold;font-size:10.5000pt;mso-font-kerning:0.0000pt;" >我的技术栈</span></b><b><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-weight:bold;font-size:10.5000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></b></p></td></tr><tr><td width=3D83  valign=3Dtop  style=3D"width:62.3000pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(102,102,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >主题描述：</span><span style=3D"font-family:微软雅黑;color:rgb(102,102,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td><td width=3D578  valign=3Dtop  style=3D"width:434.1500pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >理解面向对象编程,规范的代码和文档编写习惯。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >本科学历，英语六级，能够流畅阅读常用英文技术文档。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟练掌握jQuery和Ajax等前台开发技术，熟悉JavaScript的原型，继承。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟练掌握JSP/Servlet，JavaBean，JDBC等相关技术。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟练掌握Spring，SpringMVC，Mybatis开发框架，熟悉MVC模式和RESTful接口规范。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟练掌握Struts2，Hibernate开发框架。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉Jsonp，HttpClient等远程调用技术。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉Tomcat，Nginx的配置和使用，了解Jetty。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉权限框架，熟悉shiro框架实现加密认证及权限验证技术。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉分布式系统架构。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉非关系型数据库Radis以及实现缓存需求。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉RabbitMQ消息队列的部署及使用。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟练掌握MySQL数据库，熟悉Oracle数据库。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉Git，SVN版本控制工具，Maven依赖管理工具。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟悉Linux系统,掌握常用Bash操作，熟悉Linux+JDK+Tomcat项目部署环境的搭建。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >熟练使用Eclipse+Git/SVN+Maven开发环境进行项目开发和调试。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><br></span><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >良好的沟通和解能力，善于团队合作，逻辑思维强，能够独立思考。</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td></tr></table><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;line-height:21.0000pt;" ><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr></table><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;line-height:21.0000pt;" ><span style=3D"font-family:微软雅黑;font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr></table><p class=3DMsoNormal  style=3D"mso-pagination:widow-orphan;" ><span style=3D"font-family:微软雅黑;font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr></table><p class=3DMsoNormal  style=3D"mso-pagination:widow-orphan;" ><span style=3D"font-family:微软雅黑;font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr></table><p class=3DMsoNormal  style=3D"mso-pagination:widow-orphan;" ><span style=3D"mso-spacerun:'yes';font-family:宋体;font-size:12.0000pt;mso-font-kerning:0.0000pt;" >&nbsp;</span><span style=3D"mso-spacerun:'yes';font-family:宋体;font-size:12.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></div><!--EndFragment--></body></html>

