02,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td><td width=3D578  valign=3Dtop  style=3D"width:434.1500pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >合肥革绿信息科技有限公司</span><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td></tr></table><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;line-height:21.0000pt;" ><span style=3D"font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr><tr><td width=3D682  valign=3Dcenter  colspan=3D2  style=3D"width:511.5000pt;padding:0.0000pt 7.5000pt 0.0000pt 7.5000pt ;" ><table class=3DMsoNormalTable  style=3D"border-collapse:collapse;margin-left:10.8000pt;mso-padding-alt:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><tr><td width=3D83  valign=3Dtop  style=3D"width:62.3000pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(102,102,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >项目描述：</span><span style=3D"font-family:微软雅黑;color:rgb(102,102,102);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td><td width=3D578  valign=3Dtop  style=3D"width:434.1500pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=3DMsoNormal  style=3D"word-break:break-all;mso-pagination:widow-orphan;text-align:left;line-height:21.0000pt;" ><span style=3D"mso-spacerun:'yes';font-family:微软雅黑;color:rgb(51,51,51);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >开发环境：MyEclipse+JDK1.7+Tomcat7+MySQL5.5+Nginx+Maven+SVN</span><span style=3D"font-famil