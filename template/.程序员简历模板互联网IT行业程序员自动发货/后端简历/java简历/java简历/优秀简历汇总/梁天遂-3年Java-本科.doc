.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td><td width=436  valign=center  style="width:327.6000pt;padding:0.0000pt 0.0000pt 0.0000pt 10.5000pt ;" ><p class=33  style="margin-top:5.0000pt;margin-bottom:5.0000pt;word-break:break-all;text-autospace:ideograph-other;mso-pagination:widow-orphan;text-align:left;line-height:15.0000pt;" ><b><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-weight:bold;font-size:9.0000pt;mso-font-kerning:0.0000pt;" >项目简介</span></b><span style="font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >：</span><span style="font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p><p class=33  style="margin-top:5.0000pt;margin-bottom:5.0000pt;margin-left:0.0000pt;text-indent:18.0000pt;mso-char-indent-count:2.0000;word-break:break-all;text-autospace:ideograph-other;mso-pagination:widow-orphan;text-align:left;line-height:15.0000pt;" ><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >该项目</span><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >旨在结合电子商务推广各类市场</span><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >,把全国各地的特色项目、特色市场展示给客户,为那些正在寻找投资、正在融资的企业家提供一个参考比对的信息,同时提供信用中介,成为一个B2B、B2C的融资平台。</span><span style="font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p><p class=33  style="margin-top:5.0000pt;margin-bottom:5.0000pt;word-break:break-all;text-autospace:ideograph-other;mso-pagination:widow-orphan;text-align:left;line-height:15.0000pt;" ><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >&nbsp;&nbsp;该项目采用Struts2+&nbsp;Hibernate&nbsp;+&nbsp;Spring</span><span style="font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >&nbsp;</span><span style="font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >+</span><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >&nbsp;JQuery&nbsp;+&nbsp;</span><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >Junit搭建的分布式框架</span><span style="mso-spacerun:'yes';font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >,数据库采用MySQL</span><span style="font-family:宋体;color:rgb(0,0,0);font-size:9.0000pt;mso-font-kerning:0.0000pt;" >。</span><span style="font-family:宋体;font-size:10.0000pt;mso-font-kerning:0.0000pt;" ><o:p></o:p></span></p></td></tr></table><p class=33  style="margin-top:0.0000pt;margin-bottom:0.0000pt;word-break:break-all;text-autospace:ideograph-other;mso-pagination:widow-orphan;text-align:left;line-height:15.0000pt;" ><span style="font-family:宋体;font-size:10.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr></table><p class=33  style="margin-top:0.0000pt;margin-bottom:0.0000pt;word-break:break-all;text-autospace:ideograph-other;mso-pagination:widow-orphan;text-align:left;line-height:15.0000pt;" ><span style="font-family:宋体;font-size:10.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p></td></tr><tr><td width=640  valign=center  style="width:480.0000pt;padding:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><p class=33  style="margin-top:0.0000pt;margin-bottom:0.0000pt;text-autospace:ideograph-other;mso-pagination:widow-orphan;text-align:left;line-height:15.0000pt;" ><span style="font-family:宋体;font-size:12.0000pt;mso-font-kerning:0.0000pt;" ><o:p>&nbsp;</o:p></span></p><table class=MsoNormalTable  align=center  style="border-collapse:collapse;width:450.0000pt;margin-left:20.4000pt;mso-padding-alt:0.0000pt 0.0000pt 0.0000pt 0.0000pt ;" ><tr><td width=600  valign=center  style="width:450.0000pt;padding:0.0000pt 0.0000pt 0.0000pt 3.7500pt ;border-left