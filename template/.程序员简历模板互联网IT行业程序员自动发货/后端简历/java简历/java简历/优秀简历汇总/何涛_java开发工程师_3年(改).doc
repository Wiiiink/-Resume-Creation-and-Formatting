       mso-padding-alt:0cm 0cm 0cm 0cm'>
       <tr style='mso-yfti-irow:0;mso-yfti-firstrow:yes;height:16.5pt'>
        <td width=132 style='width:99.0pt;padding:0cm 0cm 0cm 0cm;height:16.5pt'>
        <p align=center style='text-align:center;line-height:15.0pt;word-break:
        break-all'><b><span style='mso-bidi-font-family:"Times New Roman"'>鸿雅商贸</span></b><b><span
        lang=EN-US style='font-family:新宋体;mso-bidi-font-family:"Times New Roman"'><o:p></o:p></span></b></p>
        </td>
        <td width=424 style='width:318.0pt;padding:0cm 0cm 0cm 10.5pt;
        height:16.5pt'>
        <p class=MsoNormal style='line-height:15.0pt;word-break:break-all'><b><span
        lang=EN-US style='font-size:9.0pt;mso-bidi-font-family:"Times New Roman";
        color:black'><o:p>&nbsp;</o:p></span></b></p>
        </td>
       </tr>
       <tr style='mso-yfti-irow:1;height:16.5pt'>
        <td width=132 style='width:99.0pt;padding:0cm 0cm 0cm 0cm;height:16.5pt'>
        <p class=MsoNormal><span lang=EN-US style='font-size:9.0pt;mso-bidi-font-family:
        "Times New Roman";color:black'><o:p>&nbsp;</o:p></span></p>
        </td>
        <td width=424 style='width:318.0pt;padding:0cm 0cm 0cm 10.5pt;
        height:16.5pt'>
        <p style='line-height:15.0pt;word-break:break-all'><span
        style='mso-bidi-font-family:"Times New Roman"'>软件环境：<span lang=EN-US>SpringMVC
        + Spring + MyBatis +Maven + Solrcloud + Redis + Nginx + ZooKeeper +
        FastDFS<o:p></o:p></span></span></p>
        </td>
       </tr>
       <tr style='mso-yfti-irow:2;height:16.5pt'>
        <td width=132 style='width:99.0pt;padding:0cm 0cm 0cm 0cm;height:16.5pt'>
        <p class=MsoNormal><span lang=EN-US style='font-size:9.0pt;mso-bidi-font-family:
        "Times New Roman";color:black'><o:p>&nbsp;</o:p></span></p>
        </td>
        <td width=424 style='width:318.0pt;padding:0cm 0cm 0cm 10.5pt;
        height:16.5pt'>
        <p style='line-height:15.0pt;word-break:break-all'><span
        style='mso-bidi-font-family:"Times New Roman"'>责任描述：<span lang=EN-US>1.</span>参与前期需求分析，业务模块的划分，代码编写，单元测试等工作，对软件质量负责<span
        lang=EN-US><br>
        2.</span>主要负责的功能模块有：商城后台商品管理、广告位管理，商城前台商品展示、单点登录、购物车功能<span lang=EN-US><o:p></o:p></span></span></p>
        </td>
       </tr>
       <tr style='mso-yfti-irow:3;mso-yfti-lastrow:yes;height:16.5pt'>
        <td width=132 style='width:99.0pt;padding:0cm 0cm 0cm 0cm;height:16.5pt'>
        <p class=MsoNormal><span lang=EN-US style='font-size:9.0pt;mso-bidi-font-family:
        "Times New Roman";color:black'><o:p>&nbsp;</o:p></span></p>
        </td>
        <td width=424 style='width:318.0pt;padding:0cm 0cm 0cm 10.5pt;
        height:16.5pt'>
        <p style='line-height:15.0pt;word-break:break-all'><span
        style='mso-bidi-font-family:"Times New Roman"'>项目简介：<span lang=EN-US>1.</span>基于<span
        lang=EN-US>dubbox</span>和<span lang=EN-US>zookeeper</span>实现表现层和业务层的分离，实现高并发，高可用；<span
        lang=EN-US><br>
        2.</span>使用<span lang=EN-US>nginx</span>服务器进行负载均衡，并使用它作为<span
        lang=EN-US>http</span>服务器访问静态资源；<span lang=EN-US><br>
        3.</span>使用<span lang=EN-US>Redis</span>缓存服务器减轻高并发对数据库的压力；<span
        lang=EN-US><br>
        4.</span>使用<span lang=EN-US>solrcloud</span>提高搜索服务器的全文检索性能；<span
        lang=EN-US><br>
        5.</span>使用消息队列<span lang=EN-US>ActiveMQ</span>实现分布式系统间的异步通信<span
        lang=EN-US><br>
        6.</span>使用<span lang=EN-US>FreeMarker</span>生成商品详情页<span lang=EN-US><o:p></o:p></span></span></p>
        </td>
       </tr>
      </table>
      </td>
     </tr>
     <tr style='mso-yfti-irow:1'>
      <td width=600 style='width:450.0pt;padding:0cm 0cm 0cm 0cm'>
      <table class=MsoNormalTable border=0 cellspacing=0 cellpadding=0
       style='margin-left:5.4pt;border-collapse:collapse;mso-yfti-tbllook:1184;
       mso-padding-alt:0cm 0cm 0cm 0cm'>
       <tr style='mso-yfti-irow:0;mso-yfti-firstrow:yes;height:16.5pt'>
        <td width=132 style='width:99.0pt;padding:0cm 0cm 0cm 0cm;height:16.5pt'>
        <p align=center style='text-align:center;line-height:15.0pt;word-break:
        break-all'><b style='mso-bidi-font-weight:normal'>博文图书</b><b><span
        lang=EN-US style='font-family:新宋体;mso-bidi-font-family:"Times New Roman"'><o:p></o:p></span></b></p>
        </td>
        <td width=424 style='width:318.0pt;padding:0cm 0cm 0cm 10.5pt;
        height:16.5pt'>
        <p class=MsoNormal style='line-height:15.0pt;word-break:break-all'><b><span
        lang=EN-US style='font-size:9.0pt;mso-bidi-font-family:"Times New Roman";
        color:black'><o:p>&nbsp;</o:p></span></b></p>
        </td>
       </tr>
       <tr style='mso-yfti-irow:1;height:16.5pt'>
        <td width=132 style='width:99.0pt;padding:0cm 0cm 0cm 0cm;height:16.5pt'>
        <p class=MsoNormal><span lang=EN-US style='font-size:9.0pt;mso-bidi-font-family:
        "Times New Roman";color:black'><o:p>&nbsp;</o:p></span></p>
        </td>
        <td width=424 valign=top style='width:318.0pt;padding:0cm 0cm 0cm 10.5pt;
        height:16.5pt'>
        <p class=MsoNormal><span style='font-size:9.0pt;mso-bidi-font-family:
        "Times New Roman";color:black'>软件环境：<span lang=EN-US>Struts2 + Spring +
        Hibernate + MySQL + Apache Shiro <br>
        </span>项目简介：本软件旨在帮助公司搭建一个便利的日常办公平台<span lang=EN-US>,</span>该平台严格按照管理者级别<span
        lang=EN-US>,</span>设定系统登录查看的管理权限<span lang=EN-US>,</span>本系统以图书信息管理为核心，实现了对各个图书分类的运营管理，图书信息更新和维护，订单生成系统管理，支付流程管理<span
        lang=EN-US>,</span>报表管理<span lang=EN-US>,</span>资源调度分配物流信息管理等功能。<span
        lang=EN-US><br>
        1.</span>使用<span lang=EN-US>Struts2</span>对客户请求进行拦截处理<span lang=EN-US><br>
        2.</span>利用<span lang=EN-US>Session </span>和<span lang=EN-US>Cookie</span>保存登录用户信息<span
        lang=EN-US><br>
        3.</span>使用<span lang=EN-US>Js </span>和<span lang=EN-US> AJax </span>对页面信息数据进行异步请求验证和数据回显<span
        lang=EN-US><br>
        4.</span>利用<span lang=EN-US>poi</span>实现数据输出到<span lang=EN-US>Excel</span>表格中<span
        lang=EN-US>,</span>并在线下载打印<span lang=EN-US>,</span>同时防止文件并发打印<span
        lang=EN-US><br>
        </span>责任描述：<span lang=EN-US><br>
        </span>实现不同用户权限登录<span lang=EN-US>JSP</span>页面功能展示<span lang=EN-US><br>
        </span>通过<span lang=EN-US>shiro</span>框架进行用户权限认证管理<span lang=EN-US><br>
        </span>图书信息分页查询<span lang=EN-US>,</span>展示<span lang=EN-US><br>
        </span>项目后期的代码完善</span></p>
        </td>
       </tr>
       <tr style='mso-yfti-irow:2;mso-yfti-lastrow:yes;height:16.5pt'>
